# ============================================================
# 智慧景区 AI 导览系统 - AI 引擎环境变量配置
# 使用方式：复制为 .env 并填写实际值
# ============================================================

# --- 大模型 API 配置 ---
# 支持任何兼容 OpenAI Chat Completions 协议的供应商
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# --- TTS 音频输出目录 ---
# 生成的临时 MP3 将存放在此目录（可挂载为静态文件目录）
TTS_OUTPUT_DIR=./static/audio

# --- 服务配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Java 后端地址（用于接收客流热力数据） ---
BACKEND_BASE_URL=http://localhost:9000