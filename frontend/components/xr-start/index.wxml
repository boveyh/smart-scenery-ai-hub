<!-- components/xr-start/index.wxml -->
<xr-scene 
  bind:ready="handleReady" 
  bind:assets-loaded="handleAssetsLoaded"
>
  <xr-assets>
    <!-- 加载数字人模型，建议设置 node-id 以便在 JS 中引用 -->
    <xr-asset-load 
      type="gltf" 
      asset-id="avatarModel" 
      src="/assets/model/your-digital-human.glb" 
    />
    <!-- 可选：加载动画关键帧数据 -->
    <xr-asset-load 
      type="keyframe" 
      asset-id="avatarAnim" 
      src="/assets/animation/avatar.json" 
    />
  </xr-assets>

  <!-- 环境光、平行光等 -->
  <xr-light type="ambient" color="1 1 1" intensity="1" />
  <xr-light type="directional" rotation="40 70 0" color="1 1 1" intensity="3" cast-shadow />

  <!-- 数字人模型节点，添加触摸事件和动画支持 -->
  <xr-gltf 
    id="avatarModel"
    node-id="avatarModel"
    model="avatarModel"
    anim-keyframe="avatarAnim"
    anim-autoplay="clip:idle,loop:true"
    position="0 0 0" 
    scale="1 1 1"
    mesh-shape
    bind:touch-shape="handleModelTap"
  />

  <!-- 相机配置，支持轨道控制（调试用） -->
  <xr-camera 
    id="mainCamera"
    position="0 1 4" 
    target="avatarModel" 
    clear-color="0.4 0.8 0.6 1" 
    camera-orbit-control
  />
</xr-scene>