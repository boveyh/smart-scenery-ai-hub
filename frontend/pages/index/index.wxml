<!-- pages/index/index.wxml -->
<view class="container">
  <view class="header">
    <text class="title">智慧景区导览</text>
    <text class="subtitle">AI 伴您畅游</text>
  </view>

  <!-- AI 智能导览区 -->
  <view class="section">
    <view class="section-title">AI 智能导览</view>
    <view class="card-grid">
      <view class="card" bindtap="gotoChat" data-mode="text">
        <text class="card-icon">💬</text>
        <text class="card-label">极速文本</text>
      </view>
      <view class="card" bindtap="gotoChat" data-mode="digital_human">
        <text class="card-icon">🧑‍🚀</text>
        <text class="card-label">面对面数字人</text>
      </view>
    </view>
  </view>

  <!-- 景区服务区 -->
  <view class="section">
    <view class="section-title">景区服务</view>
    <view class="card-grid">
      <view class="card" bindtap="gotoPOIs">
        <text class="card-icon">🏞️</text>
        <text class="card-label">景点列表</text>
      </view>
      <view class="card" bindtap="gotoRealtimeInfo">
        <text class="card-icon">🌤️</text>
        <text class="card-label">实时资讯</text>
      </view>
      <view class="card" bindtap="gotoARScan">
        <text class="card-icon">📸</text>
        <text class="card-label">拍照识别</text>
      </view>
    </view>
  </view>

  <!-- 景区切换 -->
  <view class="footer">
    <text class="tenant-info">当前景区：{{tenantName}}</text>
    <button class="switch-btn" bindtap="switchTenant">切换景区</button>
  </view>
</view>