<!--pages/index/index.wxml-->
<view class="container">
  <text class="title">智慧景区导览</text>
  <text class="subtitle">{{tenantName}}</text>

  <!-- AI 对话区 -->
  <view class="section-title">AI 智能导览</view>
  <button class="btn primary" bindtap="gotoChat" data-mode="text">💬 极速文本模式</button>
  <button class="btn primary" bindtap="gotoChat" data-mode="digital_human">🎭 数字人模式</button>

  <!-- 景区服务区 -->
  <view class="section-title">景区服务</view>
  <view class="grid-row">
    <button class="btn grid-btn" bindtap="gotoPOIs">🗺️ 景点列表</button>
    <button class="btn grid-btn" bindtap="gotoRealtimeInfo">🌤️ 实时资讯</button>
  </view>
  <view class="grid-row">
    <button class="btn grid-btn" bindtap="gotoARScan">📸 拍照识物</button>
    <button class="btn grid-btn" bindtap="switchTenant">🏞️ 切换景区</button>
  </view>

  <!-- 底部信息 -->
  <text class="footer-info">当前景区：{{tenantName}} · 智慧导览 v2.0</text>
</view>
