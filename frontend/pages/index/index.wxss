/* pages/index/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 40rpx;
  box-sizing: border-box;
}
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  align-self: flex-start;
  margin: 16rpx 0 8rpx 10%;
  font-weight: bold;
  letter-spacing: 2rpx;
}
.btn {
  width: 80%;
  margin: 12rpx auto;
  border-radius: 60rpx;
  font-weight: bold;
  font-size: 30rpx;
  padding: 22rpx 0;
}
.btn.primary {
  background-color: #ffffff;
  color: #764ba2;
  border: none;
}
.btn.secondary {
  background-color: rgba(255,255,255,0.25);
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.5);
}
.grid-row {
  width: 80%;
  display: flex;
  gap: 20rpx;
  margin: 0 auto;
}
.grid-btn {
  flex: 1;
  margin: 8rpx 0;
  border-radius: 40rpx;
  font-weight: bold;
  font-size: 26rpx;
  padding: 18rpx 0;
  background-color: rgba(255,255,255,0.2);
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.4);
  min-width: 0;
}
.footer-info {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}
