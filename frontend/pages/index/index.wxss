/* pages/index/index.wxss */
.container {
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #f0f7ff 0%, #ffffff 100%);
  min-height: 100vh;
}
.header {
  text-align: center;
  margin-bottom: 60rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c3e50;
}
.subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
  margin-top: 10rpx;
}
.section {
  margin-bottom: 50rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #34495e;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #3B82F6;
  padding-left: 20rpx;
}
.card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.card {
  width: 30%;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}
.card:active {
  transform: scale(0.95);
}
.card-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.card-label {
  font-size: 26rpx;
  color: #2c3e50;
}
.footer {
  margin-top: 60rpx;
  text-align: center;
}
.tenant-info {
  font-size: 28rpx;
  color: #7f8c8d;
}
.switch-btn {
  margin-top: 20rpx;
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 12rpx 40rpx;
}