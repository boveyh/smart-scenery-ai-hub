/* pages/index/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.desc {
  font-size: 32rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 80rpx;
}
.btn {
  width: 80%;
  margin: 20rpx auto;
  border-radius: 60rpx;
  font-weight: bold;
  font-size: 32rpx;
  padding: 24rpx 0;
}
.btn.primary {
  background-color: #ffffff;
  color: #764ba2;
  border: none;
}
.btn.secondary {
  background-color: rgba(255,255,255,0.25);
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.5);
}
.tenant-info {
  margin-top: 60rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}