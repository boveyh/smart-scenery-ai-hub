<!-- pages/ar-scan/ar-scan.wxml -->
<view class="container">
  <view class="preview" wx:if="{{imageUrl}}">
    <image src="{{imageUrl}}" mode="aspectFit" class="preview-img" />
    <view class="result" wx:if="{{result}}">
      <text class="result-object">识别：{{result.object}}</text>
      <text class="result-confidence">可信度：{{result.confidence}}</text>
      <text class="result-desc">{{result.description}}</text>
    </view>
  </view>

  <view class="actions">
    <button bindtap="takePhoto">📷 拍照</button>
    <button bindtap="chooseImage">🖼️ 相册</button>
  </view>

  <view class="question-area" wx:if="{{imageUrl}}">
    <input placeholder="对图片提问..." bindinput="onQuestionInput" value="{{question}}" />
    <button bindtap="askQuestion">提问</button>
  </view>
</view>