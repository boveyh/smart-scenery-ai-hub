<view class="container">
  <!-- 相机/照片预览区 -->
  <view class="preview-area">
    <image
      wx:if="{{imagePath}}"
      class="preview-image"
      src="{{imagePath}}"
      mode="aspectFit"
    />
    <view class="preview-placeholder" wx:if="{{!imagePath}}">
      <text class="placeholder-icon">&#x1F4F7;</text>
      <text class="placeholder-text">拍照或选择图片<br/>AI 识别景区植物、建筑等</text>
    </view>
  </view>

  <!-- 识别结果 -->
  <view class="result-area" wx:if="{{result}}">
    <view class="result-header">
      <text class="result-object">{{result.object}}</text>
      <text class="result-confidence">可信度 {{Math.round(result.confidence * 100)}}%</text>
    </view>
    <text class="result-desc">{{result.description}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="recognizing-tip" wx:if="{{recognizing}}">
    <view class="loading-spinner"></view>
    <text>正在识别中...</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar" wx:if="{{!recognizing}}">
    <button class="action-btn take-photo" bindtap="takePhoto" wx:if="{{!imagePath}}">
      &#x1F4F7; 拍照
    </button>
    <button class="action-btn choose-image" bindtap="chooseImage" wx:if="{{!imagePath}}">
      &#x1F5BC; 从相册选择
    </button>
    <block wx:if="{{imagePath}}">
      <button class="action-btn recognize" bindtap="startRecognize" wx:if="{{!result}}">
        &#x1F50D; 开始识别
      </button>
      <button class="action-btn retake" bindtap="resetImage">
        &#x21A9; 重新拍照
      </button>
    </block>
  </view>

  <!-- 问答输入 -->
  <view class="qa-section" wx:if="{{imagePath && result}}">
    <view class="qa-input-bar">
      <input
        class="qa-input"
        placeholder="对此图片提问（可选）"
        bindinput="onQuestionInput"
        value="{{question}}"
        confirm-type="send"
        bindconfirm="askQuestion"
      />
      <button class="qa-btn" bindtap="askQuestion" disabled="{{!question.trim()}}">提问</button>
    </view>
  </view>
</view>