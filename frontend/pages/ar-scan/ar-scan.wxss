/* pages/ar-scan/ar-scan.wxss */
.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.preview {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}
.preview-img {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #eee;
}
.result {
  margin-top: 20rpx;
}
.result-object {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  display: block;
}
.result-confidence {
  font-size: 26rpx;
  color: #888;
}
.result-desc {
  font-size: 28rpx;
  color: #555;
  margin-top: 10rpx;
}
.actions {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}
.actions button {
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}
.question-area {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
}
.question-area input {
  flex: 1;
  height: 70rpx;
  font-size: 28rpx;
  padding: 0 20rpx;
}
.question-area button {
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  padding: 0 30rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
}