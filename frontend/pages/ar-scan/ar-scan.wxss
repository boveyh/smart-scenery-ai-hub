.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #1a1a2e;
}

/* ===== 预览区 ===== */
.preview-area {
  width: 100%;
  height: 520rpx;
  background-color: #16213e;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  text-align: center;
  padding: 40rpx;
}

.placeholder-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.6;
}

/* ===== 结果区 ===== */
.result-area {
  background: linear-gradient(135deg, #0f3460, #16213e);
  margin: 20rpx;
  border-radius: 24rpx;
  padding: 30rpx;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.result-object {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.result-confidence {
  font-size: 24rpx;
  color: #40b249;
  background-color: rgba(64, 178, 73, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.7;
  display: block;
}

/* ===== 识别中 ===== */
.recognizing-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
  gap: 16rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255,255,255,0.2);
  border-top-color: #3B82F6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 操作按钮 ===== */
.action-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx;
  flex-wrap: wrap;
}

.action-btn {
  min-width: 200rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 18rpx 30rpx;
  font-weight: bold;
}

.action-btn.take-photo {
  background-color: #3B82F6;
  color: #fff;
  border: none;
}

.action-btn.choose-image {
  background-color: rgba(255,255,255,0.15);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.action-btn.recognize {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
}

.action-btn.retake {
  background-color: rgba(255,255,255,0.15);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* ===== 问答输入 ===== */
.qa-section {
  padding: 0 20rpx 30rpx;
}

.qa-input-bar {
  display: flex;
  align-items: center;
  background-color: #16213e;
  border-radius: 48rpx;
  padding: 6rpx 6rpx 6rpx 24rpx;
  border: 2rpx solid rgba(255,255,255,0.1);
}

.qa-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
  padding: 16rpx 0;
}

.qa-input::placeholder {
  color: rgba(255,255,255,0.4);
}

.qa-btn {
  background-color: #3B82F6;
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border: none;
  margin: 0;
}

.qa-btn[disabled] {
  opacity: 0.5;
}