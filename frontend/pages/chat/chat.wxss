/* pages/chat/chat.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f7fa;
}
.mode-switch {
  display: flex;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}
.mode-switch button {
  flex: 1;
  margin: 0 10rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #555;
}
.mode-switch .active {
  background: #3B82F6;
  color: white;
}

/* 文本模式 */
.msg-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}
.msg {
  margin: 10rpx 0;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  max-width: 80%;
  word-break: break-all;
}
.msg.user {
  align-self: flex-end;
  background: #3B82F6;
  color: white;
  margin-left: auto;
}
.msg.assistant {
  background: white;
  color: #333;
  border: 1rpx solid #e0e0e0;
}
.msg.system {
  background: #fff3cd;
  color: #856404;
  text-align: center;
  width: 100%;
  font-size: 24rpx;
}
.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid #e0e0e0;
}
.input-bar input {
  flex: 1;
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 40rpx;
  padding: 0 20rpx;
  margin-right: 20rpx;
}
.input-bar button {
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  padding: 0 30rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
}

/* 数字人模式 */
.player-wrapper {
  width: 100%;
  flex: 1;
  background: #000;
}
.subtitle-area {
  padding: 20rpx 30rpx;
  background: rgba(0,0,0,0.7);
  color: white;
  font-size: 28rpx;
  text-align: center;
  min-height: 80rpx;
}
.clothing-btn {
  margin: 20rpx auto;
  background: #ff7e5f;
  color: white;
  border-radius: 40rpx;
  padding: 12rpx 40rpx;
  font-size: 28rpx;
}