<!-- pages/chat/chat.wxml -->
<view class="container">
  <!-- 模式切换 -->
  <view class="mode-switch">
    <button class="{{mode === 'text' ? 'active' : ''}}" bindtap="switchMode" data-mode="text">📝 极速文本</button>
    <button class="{{mode === 'digital_human' ? 'active' : ''}}" bindtap="switchMode" data-mode="digital_human">🎭 数字人</button>
  </view>

  <!-- 文本模式 -->
  <block wx:if="{{mode === 'text'}}">
    <scroll-view class="msg-list" scroll-y scroll-into-view="{{lastMsgId}}">
      <view wx:for="{{messages}}" wx:key="index" class="msg {{item.role}}">
        <text>{{item.content}}</text>
      </view>
    </scroll-view>
    <view class="input-bar">
      <input placeholder="说句话或打字..." bindinput="onInput" value="{{inputText}}" />
      <button size="mini" bindtap="sendText">发送</button>
      <button size="mini" bindtap="startVoice">🎤</button>
    </view>
  </block>

  <!-- 数字人模式 -->
  <block wx:if="{{mode === 'digital_human'}}">
    <view class="player-wrapper">
      <live-player
        id="digitalHumanPlayer"
        src="{{streamUrl}}"
        mode="live"
        autoplay="{{true}}"
        bindstatechange="onPlayStateChange"
        style="width: 100%; height: 70vh;"
      />
    </view>
    <view class="subtitle-area">{{currentSubtitle}}</view>
    <button class="clothing-btn" bindtap="openClothingPanel">👗 换装</button>
  </block>
</view>