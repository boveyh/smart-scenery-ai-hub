<!--pages/chat/chat.wxml-->
<view class="container">
  <!-- 模式切换开关 -->
  <view class="mode-switch">
    <button class="{{mode === 'text' ? 'active' : ''}}" bindtap="switchMode" data-mode="text">📝 极速文本</button>
    <button class="{{mode === 'digital_human' ? 'active' : ''}}" bindtap="switchMode" data-mode="digital_human">🎭 数字人</button>
  </view>

  <!-- ==================== 极速文本模式界面 ==================== -->
  <block wx:if="{{mode === 'text'}}">
    <scroll-view class="msg-list" scroll-y scroll-into-view="{{lastMsgId}}" scroll-with-animation>
      <block wx:for="{{messages}}" wx:key="index">
        <view wx:if="{{item.role !== 'system'}}" class="msg {{item.role}}">
        <text>{{item.content}}</text>
          <text wx:if="{{item.role === 'assistant' && !item.finished}}" class="typing-dot">●</text>
      </view>
        <view wx:if="{{item.role === 'system'}}" class="msg system">
          <text>{{item.content}}</text>
    </view>
  </block>
    </scroll-view>
    <view class="input-bar">
      <input
        placeholder="输入问题..."
        bindinput="onInput"
        value="{{inputText}}"
        confirm-type="send"
        bindconfirm="sendText"
        disabled="{{isTyping}}"
      />
      <button size="mini" bindtap="sendText" disabled="{{isTyping}}">发送</button>
      <button size="mini" bindtap="startVoice">🎤</button>
    </view>
  </block>

  <!-- ==================== 数字人模式界面 ==================== -->
  <block wx:if="{{mode === 'digital_human'}}">
    <!-- 视频展示区域 -->
    <view class="dh-video-area">
      <video
        class="dh-video"
        src="{{videoSrc}}"
        autoplay
        loop
        muted
        object-fit="contain"
        show-center-play-btn="{{false}}"
        show-fullscreen-btn="{{false}}"
        controls="{{false}}"
      ></video>
</view>

    <!-- 消息/字幕区域 -->
    <view class="dh-content">
      <scroll-view class="msg-list dh-msg-list" scroll-y scroll-into-view="{{lastMsgId}}" scroll-with-animation>
        <block wx:for="{{messages}}" wx:key="index">
          <view class="msg {{item.role}}">
            <text>{{item.content}}</text>
            <text wx:if="{{item.role === 'assistant' && !item.finished}}" class="typing-dot">●</text>
          </view>
        </block>
      </scroll-view>
    </view>

    <!-- 字幕条 -->
    <view class="dh-subtitle" wx:if="{{subtitleText}}">
      <text class="subtitle-text">{{subtitleText}}</text>
    </view>

    <!-- 输入栏 -->
    <view class="input-bar">
      <input
        placeholder="输入问题..."
        bindinput="onInput"
        value="{{inputText}}"
        confirm-type="send"
        bindconfirm="sendText"
        disabled="{{isTyping}}"
      />
      <button size="mini" bindtap="sendText" disabled="{{isTyping}}">发送</button>
      <button size="mini" bindtap="startVoice">🎤</button>
    </view>
  </block>
</view>

