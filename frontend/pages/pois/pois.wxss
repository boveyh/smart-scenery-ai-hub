/* pages/pois/pois.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f7fa;
}
.category-bar {
  white-space: nowrap;
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
}
.category-item {
  display: inline-block;
  padding: 10rpx 30rpx;
  margin-right: 20rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #555;
}
.category-item.active {
  background: #3B82F6;
  color: white;
}
.sort-bar {
  padding: 20rpx 30rpx;
  background: white;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
}
.sort-option {
  margin-left: 30rpx;
  color: #888;
}
.sort-option.active {
  color: #3B82F6;
  font-weight: bold;
}
.poi-list {
  flex: 1;
  padding: 20rpx 30rpx;
}
.poi-card {
  display: flex;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.poi-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #eee;
}
.poi-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.poi-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
}
.poi-category {
  font-size: 24rpx;
  color: #7f8c8d;
  margin-top: 4rpx;
}
.poi-desc {
  font-size: 26rpx;
  color: #555;
  margin: 8rpx 0;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.poi-meta {
  display: flex;
  font-size: 24rpx;
  color: #888;
}
.crowdedness {
  margin-right: 30rpx;
}
.loading, .empty {
  text-align: center;
  padding: 60rpx 0;
  color: #888;
}