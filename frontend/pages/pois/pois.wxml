<!-- pages/pois/pois.wxml -->
<view class="container">
  <!-- 分类筛选 -->
  <scroll-view class="category-bar" scroll-x>
    <view wx:for="{{categories}}" wx:key="index" class="category-item {{currentCategory === item ? 'active' : ''}}" bindtap="selectCategory" data-cat="{{item}}">
      {{item}}
    </view>
  </scroll-view>

  <!-- 排序 -->
  <view class="sort-bar">
    <text class="sort-label">排序：</text>
    <text class="sort-option {{sortBy === 'default' ? 'active' : ''}}" bindtap="setSort" data-sort="default">默认</text>
    <text class="sort-option {{sortBy === 'crowdedness' ? 'active' : ''}}" bindtap="setSort" data-sort="crowdedness">拥挤度</text>
    <text class="sort-option {{sortBy === 'distance' ? 'active' : ''}}" bindtap="setSort" data-sort="distance">距离</text>
  </view>

  <!-- 列表 -->
  <scroll-view class="poi-list" scroll-y>
    <view wx:for="{{pois}}" wx:key="poiId" class="poi-card" bindtap="gotoDetail" data-id="{{item.poiId}}">
      <image src="{{item.imageUrl || '/assets/default-poi.png'}}" mode="aspectFill" class="poi-img" />
      <view class="poi-info">
        <text class="poi-name">{{item.name}}</text>
        <text class="poi-category">{{item.category}}</text>
        <text class="poi-desc">{{item.description}}</text>
        <view class="poi-meta">
          <text class="crowdedness">拥挤度：{{item.crowdedness}}/5</text>
          <text class="stay">建议停留 {{item.avgStayMin}}min</text>
        </view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!loading && pois.length === 0}}" class="empty">暂无景点</view>
  </scroll-view>
</view>