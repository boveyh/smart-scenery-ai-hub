/* pages/poi-detail/poi-detail.wxss */
.container {
  background: white;
}
.header-img {
  width: 100%;
  height: 400rpx;
  background: #eee;
}
.content {
  padding: 30rpx;
}
.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c3e50;
}
.tags {
  margin: 20rpx 0;
}
.tag {
  display: inline-block;
  background: #f0f0f0;
  border-radius: 40rpx;
  padding: 6rpx 24rpx;
  font-size: 24rpx;
  color: #555;
  margin-right: 20rpx;
}
.tag.crowdedness {
  background: #ff7e5f;
  color: white;
}
.info-grid {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.desc {
  font-size: 30rpx;
  line-height: 1.6;
  color: #555;
  margin: 20rpx 0;
}
.chart-section {
  margin: 30rpx 0;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #34495e;
  display: block;
  margin-bottom: 20rpx;
}
.chart {
  width: 100%;
  height: 300rpx;
}
.action-buttons {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
}
.action-buttons button {
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  padding: 12rpx 30rpx;
  font-size: 28rpx;
}