<view class="container">
  <!-- 加载状态 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && poi}}">
    <!-- 顶部图片 -->
    <view class="header-image-wrap">
      <image class="header-image" src="{{poi.imageUrl || '/assets/default-poi.png'}}" mode="aspectFill" />
      <view class="header-overlay">
        <text class="header-name">{{poi.name}}</text>
        <text class="header-category">{{poi.category}}{{poi.subCategory ? ' · ' + poi.subCategory : ''}}</text>
      </view>
    </view>

    <!-- 拥挤度 & 基本信息 -->
    <view class="info-section">
      <view class="crowdedness-row">
        <text class="section-label">当前拥挤度</text>
        <view class="crowd-badge level-{{poi.crowdedness}}">
          <text>{{crowdText}}</text>
        </view>
      </view>
      <view class="info-grid">
        <view class="info-item" wx:if="{{poi.openingHours}}">
          <text class="info-icon">&#x1F552;</text>
          <text class="info-label">开放时间</text>
          <text class="info-value">{{poi.openingHours}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">&#x1F4B0;</text>
          <text class="info-label">门票价格</text>
          <text class="info-value">{{poi.ticketPrice > 0 ? '¥' + poi.ticketPrice : '免费'}}</text>
        </view>
        <view class="info-item" wx:if="{{poi.avgStayMin}}">
          <text class="info-icon">&#x23F1;</text>
          <text class="info-label">建议停留</text>
          <text class="info-value">{{poi.avgStayMin}}分钟</text>
        </view>
        <view class="info-item" wx:if="{{poi.address}}">
          <text class="info-icon">&#x1F4CD;</text>
          <text class="info-label">地址</text>
          <text class="info-value">{{poi.address}}</text>
        </view>
      </view>
    </view>

    <!-- 景点简介 -->
    <view class="desc-section">
      <text class="section-title">景点简介</text>
      <text class="desc-content">{{poi.description || '暂无详细介绍'}}</text>
    </view>

    <!-- 拥挤度历史 -->
    <view class="section" wx:if="{{crowdHistory.length > 0}}">
      <text class="section-title">拥挤度趋势（近24小时）</text>
      <view class="history-bar">
        <view
          class="history-item"
          wx:for="{{crowdHistory}}"
          wx:key="index"
        >
          <view class="history-bar-fill" style="height: {{(item.crowdedness / 5) * 100}}%"></view>
          <text class="history-time">{{item.time}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button class="action-btn primary" bindtap="goToChat">&#x1F4AC; AI 问答</button>
      <button class="action-btn secondary" bindtap="goToRoute">&#x1F9ED; 推荐路线</button>
      <button class="action-btn secondary" bindtap="goToAR">&#x1F4F7; 拍照识物</button>
    </view>
  </block>
</view>