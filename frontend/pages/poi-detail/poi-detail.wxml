<!-- pages/poi-detail/poi-detail.wxml -->
<view class="container">
  <image src="{{poi.imageUrl || '/assets/default-poi.png'}}" mode="aspectFill" class="header-img" />
  <view class="content">
    <text class="name">{{poi.name}}</text>
    <view class="tags">
      <text class="tag">{{poi.category}}</text>
      <text class="tag crowdedness">拥挤度 {{poi.crowdedness}}/5</text>
    </view>
    <view class="info-grid">
      <text>🕒 开放时间：{{poi.openTime || '全天'}}</text>
      <text>💰 门票：{{poi.ticketPrice || '免费'}}</text>
      <text>⏳ 建议停留：{{poi.avgStayMin || 30}}分钟</text>
      <text>📍 地址：{{poi.address || '景区内'}}</text>
    </view>
    <text class="desc">{{poi.description}}</text>

    <view class="chart-section">
      <text class="section-title">拥挤度趋势（近24h）</text>
      <canvas canvas-id="crowdChart" class="chart"></canvas>
    </view>

    <view class="action-buttons">
      <button bindtap="goChat" data-mode="text">💬 AI 问答</button>
      <button bindtap="goRoute">🗺️ 推荐路线</button>
      <button bindtap="goScan">📸 拍照识别</button>
    </view>
  </view>
</view>