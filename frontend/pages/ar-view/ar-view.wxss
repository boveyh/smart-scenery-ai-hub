/* pages/ar-view/ar-view.wxss */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e9edf5 100%);
  padding: 40rpx;
  box-sizing: border-box;
}
.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
  width: 100%;
  max-width: 600rpx;
}
.icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 20rpx;
}
.desc {
  font-size: 30rpx;
  color: #7f8c8d;
  text-align: center;
  margin-bottom: 10rpx;
}
.hint {
  font-size: 26rpx;
  color: #b0b0b0;
  margin-bottom: 50rpx;
}
.jump-btn {
  background: #3B82F6;
  color: white;
  border-radius: 60rpx;
  padding: 24rpx 0;
  width: 80%;
  font-size: 32rpx;
  font-weight: 500;
}