<!-- pages/route-recommend/route-recommend.wxml -->
<view class="container">
  <view class="form">
    <view class="field">
      <text>兴趣偏好</text>
      <picker mode="selector" range="{{interestOptions}}" bindchange="onInterestChange">
        <view class="picker">{{interest}}</view>
      </picker>
    </view>
    <view class="field">
      <text>游览节奏</text>
      <picker mode="selector" range="{{paceOptions}}" bindchange="onPaceChange">
        <view class="picker">{{pace}}</view>
      </picker>
    </view>
    <view class="field">
      <text>同行人</text>
      <picker mode="selector" range="{{companionOptions}}" bindchange="onCompanionChange">
        <view class="picker">{{companion}}</view>
      </picker>
    </view>
    <view class="field">
      <text>游览时长（分钟）</text>
      <slider min="60" max="360" value="{{duration}}" bindchange="onDurationChange" show-value />
    </view>
    <button bindtap="getRecommendation">生成路线</button>
  </view>

  <view class="result" wx:if="{{route}}">
    <text class="result-title">推荐路线</text>
    <text class="route-id">路线编号：{{route.routeId}}</text>
    <view class="timeline">
      <view wx:for="{{route.poiDetails}}" wx:key="poiId" class="step">
        <text class="step-index">{{index + 1}}</text>
        <view class="step-content">
          <text class="step-name">{{item.name}}</text>
          <text class="step-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
    <text class="total-time">预计总时长：{{route.estimatedTimeMin}} 分钟</text>
    <view class="tips" wx:if="{{route.tips && route.tips.length > 0}}">
      <text class="tips-title">温馨提示</text>
      <text wx:for="{{route.tips}}" wx:key="index" class="tip-item">• {{item}}</text>
    </view>
    <button bindtap="reset">重新选择</button>
  </view>
</view>