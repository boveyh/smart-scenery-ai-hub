.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
}

/* ===== 表单 ===== */
.form-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #212529;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #495057;
  display: block;
  margin-bottom: 14rpx;
  font-weight: bold;
}

.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background-color: #f1f3f5;
  color: #495057;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}

.option.active {
  background-color: #e8f0fe;
  color: #3B82F6;
  border-color: #3B82F6;
  font-weight: bold;
}

.submit-btn {
  width: 100%;
  margin-top: 16rpx;
  background-color: #3B82F6;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 22rpx 0;
  font-weight: bold;
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* ===== 结果 ===== */
.result-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e9ecef;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #212529;
  display: block;
}

.result-time {
  font-size: 28rpx;
  color: #3B82F6;
  margin-top: 8rpx;
  display: block;
}

/* ===== 路线时间线 ===== */
.route-timeline {
  padding-left: 20rpx;
}

.route-step {
  display: flex;
  margin-bottom: 24rpx;
  position: relative;
}

.route-step::before {
  content: '';
  position: absolute;
  left: 32rpx;
  top: 60rpx;
  bottom: -24rpx;
  width: 4rpx;
  background-color: #e9ecef;
}

.route-step:last-child::before {
  display: none;
}

.step-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #3B82F6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.step-dot.crowded {
  background-color: #fd7e14;
}

.step-num {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.step-content {
  flex: 1;
  padding-bottom: 12rpx;
}

.step-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #212529;
  display: block;
  margin-bottom: 6rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #6c757d;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.step-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.step-meta-item {
  font-size: 22rpx;
  background-color: #f1f3f5;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  color: #868e96;
}

.step-meta-item.crowd-level-4, .step-meta-item.crowd-level-5 {
  background-color: #fff5f5;
  color: #dc3545;
}

.step-meta-item.crowd-level-3 {
  background-color: #fff9db;
  color: #e67700;
}

/* ===== 温馨提示 ===== */
.tips-section {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #fff9db;
  border-radius: 16rpx;
  border: 1rpx solid #ffecb3;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #856404;
  display: block;
  margin-bottom: 12rpx;
}

.tip-item {
  display: flex;
  margin-bottom: 8rpx;
}

.tip-dot {
  color: #856404;
  margin-right: 8rpx;
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #856404;
  flex: 1;
  line-height: 1.5;
}

/* ===== 操作按钮 ===== */
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.action-btn {
  flex: 1;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  font-weight: bold;
}

.action-btn.primary {
  background-color: #3B82F6;
  color: #fff;
  border: none;
}

.action-btn.secondary {
  background-color: #fff;
  color: #3B82F6;
  border: 2rpx solid #3B82F6;
}

/* ===== 加载 ===== */
.loading-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  font-size: 30rpx;
  color: #868e96;
}