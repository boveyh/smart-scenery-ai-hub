/* pages/route-recommend/route-recommend.wxss */
.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.form {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.field {
  margin-bottom: 30rpx;
}
.field text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.picker {
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #555;
}
button {
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  margin-top: 20rpx;
}
.result {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
}
.result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2c3e50;
  display: block;
  margin-bottom: 30rpx;
}
.step {
  display: flex;
  margin-bottom: 30rpx;
}
.step-index {
  width: 50rpx;
  height: 50rpx;
  background: #3B82F6;
  color: white;
  border-radius: 50%;
  text-align: center;
  line-height: 50rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}
.step-content {
  margin-left: 20rpx;
  border-left: 2rpx solid #ddd;
  padding-left: 20rpx;
  padding-bottom: 20rpx;
  flex: 1;
}
.step-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.step-desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 6rpx;
}
.total-time {
  display: block;
  font-size: 28rpx;
  color: #ff7e5f;
  margin: 20rpx 0;
  text-align: center;
}
.tips {
  margin-top: 30rpx;
  background: #fff3cd;
  border-radius: 16rpx;
  padding: 20rpx;
}
.tips-title {
  font-weight: 600;
  font-size: 28rpx;
  color: #856404;
}
.tip-item {
  display: block;
  font-size: 26rpx;
  color: #856404;
  margin-top: 10rpx;
}