<!-- pages/realtime-info/realtime-info.wxml -->
<view class="container">
  <!-- 顶层守卫：info 未就绪时显示加载占位 -->
  <block wx:if="{{!info}}">
    <view class="loading-hint">加载中...</view>
  </block>

  <block wx:else>
    <view class="weather-card">
      <text class="weather-temp">{{info.temperature}}°C</text>
      <text class="weather-desc">{{info.weather}}</text>
      <view class="weather-detail">
        <text>💧 湿度 {{info.humidity}}%</text>
        <text>💨 风速 {{info.windSpeed}} km/h</text>
      </view>
      <text class="crowd-level">整体拥挤度：{{info.crowdednessLevel}}/5</text>
    </view>

    <view class="section">
      <text class="section-title">热门景点拥挤度</text>
      <block wx:if="{{info.peakPois && info.peakPois.length > 0}}">
        <view wx:for="{{info.peakPois}}" wx:key="poiId" class="bar-item">
          <text class="bar-name">{{item.name}}</text>
          <view class="bar-bg">
            <view class="bar-fill" style="width: {{(item.crowdedness || 0) / 5 * 100 + '%'}};"></view>
          </view>
          <text class="bar-value">{{item.crowdedness}}/5</text>
        </view>
      </block>
      <view wx:else class="empty-hint">暂无热门景点数据</view>
    </view>

    <view class="section">
      <text class="section-title">公告</text>
      <block wx:if="{{info.announcements && info.announcements.length > 0}}">
        <view wx:for="{{info.announcements}}" wx:key="*this" class="announcement">
          <text>{{item}}</text>
        </view>
      </block>
      <view wx:else class="empty-hint">暂无公告</view>
    </view>
  </block>

  <button bindtap="refresh" class="refresh-btn">🔄 刷新</button>
</view>