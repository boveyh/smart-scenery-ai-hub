/* pages/realtime-info/realtime-info.wxss */
.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.weather-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: white;
  margin-bottom: 30rpx;
}
.weather-temp {
  font-size: 72rpx;
  font-weight: bold;
  display: block;
}
.weather-desc {
  font-size: 32rpx;
  display: block;
}
.weather-detail {
  display: flex;
  justify-content: space-between;
  margin: 20rpx 0;
  font-size: 28rpx;
}
.crowd-level {
  font-size: 30rpx;
}
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  display: block;
  margin-bottom: 20rpx;
}
.bar-item {
  display: flex;
  align-items: center;
  margin: 16rpx 0;
}
.bar-name {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
}
.bar-bg {
  flex: 1;
  height: 30rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  margin: 0 20rpx;
}
.bar-fill {
  height: 100%;
  background: #3B82F6;
  border-radius: 20rpx;
  transition: width 0.3s;
}
.bar-value {
  font-size: 24rpx;
  color: #888;
  width: 60rpx;
  text-align: right;
}
.announcement {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 10rpx 0;
  font-size: 28rpx;
  color: #555;
}
.empty-hint {
  text-align: center;
  font-size: 28rpx;
  color: #aaa;
  padding: 30rpx 0;
}
.refresh-btn {
  background: #3B82F6;
  color: white;
  border-radius: 40rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
}